{
  "info": {
    "name": "FIT4110_lab03_team_analytics",
    "description": "Postman Collection for Analytics Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "1. GET /analytics/events (Danh sách sự kiện, Limit)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has items array\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"items\");",
                  "    pm.expect(json.items).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/events?limit=20&eventType=telemetry.ingested",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "events"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "eventType",
                  "value": "telemetry.ingested"
                }
              ]
            }
          }
        },
        {
          "name": "2. POST /analytics/iot-events (Ghi nhận IoT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"SENSOR-001\",\n  \"metric\": \"temperature\",\n  \"value\": 38.5,\n  \"timestamp\": \"2023-11-20T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analytics/iot-events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "iot-events"
              ]
            }
          }
        },
        {
          "name": "3. GET /analytics/kpi (Lấy KPI Dashboard)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has kpiId and value\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"kpiId\");",
                  "    pm.expect(json).to.have.property(\"value\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/kpi",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "kpi"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "4. Missing Token (401 Unauthorized)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Unauthorized request returns 401 or 403\", function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/analytics/kpi",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "kpi"
              ]
            }
          }
        },
        {
          "name": "5. Invalid Token (401 Unauthorized)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Unauthorized request returns 401 or 403\", function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid_token",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/kpi",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "kpi"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "6. Invalid Payload (Thiếu deviceId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Invalid payload returns client error (400 or 422)\", function () {",
                  "    pm.expect([400, 422]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test(\"Error response follows ProblemDetails\", function () {",
                  "    if ([400, 422].includes(pm.response.code)) {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json).to.have.property(\"status\");",
                  "        pm.expect(json.status).to.be.within(400, 599);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"temperature\",\n  \"value\": 38.5,\n  \"timestamp\": \"2023-11-20T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analytics/iot-events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "iot-events"
              ]
            }
          }
        },
        {
          "name": "7. Lỗi NotFound Analytics Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Return 404 for non-existent report\", function () {",
                  "    pm.expect([404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/report/fake-uuid",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "report",
                "fake-uuid"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "8. Rate Limit or Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Rate limit or Success is handled\", function () {",
                  "    pm.expect([200, 429]).to.include(pm.response.code);",
                  "    if (pm.response.code === 429) {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json).to.have.property(\"detail\");",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/kpi",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "kpi"
              ]
            }
          }
        },
        {
          "name": "9. Boundary Limit (> 100)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Boundary limit over 100 might be rejected or truncated\", function () {",
                  "    pm.expect([200, 400, 422]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/events?limit=9999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analytics",
                "events"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "9999"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "10. Gọi mock Core Business",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Core Business Mock is alive and returns valid response\", function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{coreBusinessMockUrl}}/health",
              "host": [
                "{{coreBusinessMockUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "11. Latency check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get(\"env\") === \"local\") {",
                  "  pm.test(\"Response time is below 1000ms on local service\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    }
  ]
}
